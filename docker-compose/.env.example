# ============================================================================
# Environment Configuration for Art Gallery Application
# ============================================================================
# Copy this file to .env and update the values for your environment
# ============================================================================

# SQL Server Configuration
# IMPORTANT: Change this to a strong, unique password in production
SQLSERVER_SA_PASSWORD=ChangeMeToASecurePassword123!

# CORS Configuration
# Add additional origins separated by commas
# Development: http://localhost:3000
# Production: https://yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# API Configuration
# The API container runs on port 8080 internally
# In development, this port is exposed to localhost:8080
API_PORT=8080

# Frontend Configuration
# The frontend container runs on port 3000 internally
# In development, this port is exposed to localhost:3000
FRONTEND_PORT=3000

# ============================================================================
# API URL Configuration
# ============================================================================
# IMPORTANT: Understanding the two API URLs
#
# NEXT_PUBLIC_API_URL: Used by the BROWSER to access the API
#   - Development: Browser accesses API directly at http://localhost:8080/api
#   - Production: Browser accesses API via NGINX at /api (same domain, no CORS)
#
# SERVER_API_URL: Used by Next.js SERVER COMPONENTS inside Docker container
#   - Always uses internal Docker network URL: http://api:8080/api
#   - This is NOT exposed to the browser (no NEXT_PUBLIC_ prefix)
# ============================================================================

# Development mode (default) - Docker without NGINX
NEXT_PUBLIC_API_URL=http://localhost:8080/api
SERVER_API_URL=http://api:8080/api

# Production mode (uncomment these when deploying with NGINX):
# NEXT_PUBLIC_API_URL=/api
# SERVER_API_URL=http://api:8080/api

# ============================================================================
# NGINX Configuration (Production Only)
# ============================================================================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_HEALTH_PORT=8080