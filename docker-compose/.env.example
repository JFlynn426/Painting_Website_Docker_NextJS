# ============================================================================
# Environment Configuration for Art Gallery Application
# ============================================================================
# Copy this file to .env and update the values for your environment
# ============================================================================

# SQL Server Configuration
# IMPORTANT: Change this to a strong, unique password in production
SQLSERVER_SA_PASSWORD=ChangeMeToASecurePassword123!

# CORS Configuration
# Add additional origins separated by commas
# Development: http://localhost:3000
# Production: https://yourdomain.com
CORS_ALLOWED_ORIGINS=http://localhost:3000

# API Configuration
API_PORT=5000

# Frontend Configuration
FRONTEND_PORT=3000

# ============================================================================
# API URL Configuration
# ============================================================================
# For DEVELOPMENT (Docker without NGINX):
#   - Browser accesses API directly at http://localhost:8080/api
#   - Next.js server accesses API via Docker network at http://api:8080/api
#
# For PRODUCTION (Docker with NGINX):
#   - Browser accesses API via NGINX at /api (same domain, no CORS issues)
#   - Next.js server accesses API via Docker network at http://api:8080/api
#
# For CLOUDFLARE (Docker with NGINX + Cloudflare Full mode):
#   - Browser accesses via HTTPS at https://yourdomain.com/api
#   - Cloudflare connects to NGINX via HTTPS
#   - NGINX terminates SSL and proxies to containers via HTTP
#   - Next.js server accesses API via Docker network at http://api:8080/api
# ============================================================================

# Development mode (default)
NEXT_PUBLIC_API_URL=http://localhost:8080/api
SERVER_API_URL=http://api:8080/api

# Production mode with NGINX (uncomment when deploying with docker-compose.prod.yml):
# NEXT_PUBLIC_API_URL=/api
# SERVER_API_URL=http://api:8080/api

# Cloudflare Full mode (uncomment when deploying with docker-compose.cloudflare.yml):
# NEXT_PUBLIC_API_URL=https://yourdomain.com/api
# SERVER_API_URL=http://api:8080/api

# ============================================================================
# NGINX Configuration (Production Only)
# ============================================================================
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443
NGINX_HEALTH_PORT=8080

# ============================================================================
# Deployment Mode Selection
# ============================================================================
# Choose ONE of the following deployment modes:
#
# 1. LOCAL DEVELOPMENT (default):
#    - Use: docker-compose up -d
#    - Keep default values above
#    - Access: http://localhost:3000
#
# 2. PRODUCTION WITH NGINX (self-hosted):
#    - Use: docker-compose -f docker-compose.prod.yml up -d --build
#    - Uncomment: NEXT_PUBLIC_API_URL=/api
#    - Set CORS_ALLOWED_ORIGINS to your domain
#    - Requires SSL certificates in nginx/ssl/
#
# 3. CLOUDFLARE FULL MODE (recommended for home servers):
#    - Use: docker-compose -f docker-compose.cloudflare.yml up -d --build
#    - Uncomment: NEXT_PUBLIC_API_URL=https://yourdomain.com/api
#    - Set CORS_ALLOWED_ORIGINS=https://yourdomain.com
#    - Requires self-signed SSL certificate in nginx/ssl/
#    - Cloudflare handles SSL at edge, NGINX terminates with self-signed cert
# ============================================================================